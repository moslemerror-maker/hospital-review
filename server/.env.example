PORT=5000
MONGO_URI=mongodb://<user>:<password>@<cluster-url>/?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string
GOOGLE_PLACE_ID=your-google-place-id

# Frontend URL — must match wherever the client is actually deployed.
# QR codes and WhatsApp share links are generated from this value.
FRONTEND_URL=http://localhost:5173

# Gupshup WhatsApp API
GUPSHUP_API_KEY=your-gupshup-api-key
GUPSHUP_SOURCE_NUMBER=910000000000
GUPSHUP_APP_NAME=your-gupshup-app-name
